#!/usr/bin/env python3
"""cp-panel-data — snapshot JSON de TODAS as sessões (deste servidor + peers) pro painel do
Quickshell. Existe pra manter o QML burro: ele só roda isto e faz JSON.parse, sem token, sem
merge de servidor, sem HTTP na mão.

Saída: {"sessions": [...], "errors": [...], "servers": [...]} — sessão local tem server=null e
address=<nome>;
remota tem server=<id> e address=<id>::<nome> (o mesmo endereço que o cp-send aceita).
Servidor fora do ar entra em errors e NÃO derruba o resto (painel degrada, não some).

servers[] lista TODO peer do peers.json com {id, enabled, ok, error} — inclusive o desligado,
que fica fora da varredura mas precisa aparecer no painel pra ter como religar.
"""
import json
import os
import subprocess
import sys
import urllib.error
import urllib.request
from concurrent.futures import ThreadPoolExecutor

# resolve(): roda via symlink em ~/.local/bin — sem resolver, o import iria procurar lá.
sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
from cp_panel_common import PanelError, enabled, env, local_base, peer_fields, peers  # noqa: E402

TIMEOUT = 4

# Campos que o painel usa. Enxugar aqui evita despejar o transcript inteiro no QML a cada poll.
KEEP = ("name", "cwd", "state", "branch", "status_line", "question", "options", "stalled",
        "limited", "pair_peers", "provider", "last_activity")


def fetch(base_url: str, token: str) -> list[dict]:
    req = urllib.request.Request(f"{base_url.rstrip('/')}/api/sessions",
                                 headers={"Authorization": f"Bearer {token}"})
    with urllib.request.urlopen(req, timeout=TIMEOUT) as resp:
        return json.load(resp)


def fetch_projects(base_url: str, token: str) -> tuple[list, str]:
    """Launcher de projetos — SO do servidor local: o projects.json descreve caminhos desta
    maquina, e play/stop remoto nao existe. Falha vira linha de erro, nunca derruba a coleta."""
    req = urllib.request.Request(f"{base_url.rstrip('/')}/api/projects",
                                 headers={"Authorization": f"Bearer {token}"})
    try:
        with urllib.request.urlopen(req, timeout=TIMEOUT) as resp:
            data = json.load(resp)
            return (data if isinstance(data, list) else []), ""
    except Exception as e:
        return [], f"projetos: {e}"


def attached_locally() -> set[str]:
    """Sessões tmux DESTA máquina com pelo menos um cliente. Diz ao painel se o clique vai focar
    um terminal já aberto ou abrir um novo. Só faz sentido local — sessão remota abre a web UI."""
    try:
        out = subprocess.run(["tmux", "list-clients", "-F", "#{session_name}"],
                             capture_output=True, text=True, timeout=3, check=True).stdout
        return {line.strip() for line in out.splitlines() if line.strip()}
    except (OSError, subprocess.SubprocessError):
        return set()      # sem tmux/servidor: ninguém attachado, não é erro pro painel.


def slim(s: dict, server: str | None, web: str = "", attached: set[str] = frozenset()) -> dict:
    out = {k: s.get(k) for k in KEEP}
    out["server"] = server
    out["address"] = f"{server}::{s['name']}" if server else s["name"]
    # local=True: só nestas dá pra `tmux attach` nesta máquina; remota abre a web UI.
    out["local"] = server is None
    # web_url: onde o painel abre a sessão remota. Vem do peers.json ("web_url", senão base_url)
    # — NÃO dá pra derivar do id: nem todo servidor está atrás de tailscale serve (um responde
    # em IP:porta crua), então um padrão chumbado tipo <id>.ts.net abriria link quebrado.
    out["web_url"] = f"{web.rstrip('/')}/#/{s['name']}" if web else ""
    out["attached"] = server is None and s["name"] in attached
    # group: chave de seção do painel. Local e remoto viram blocos separados porque a AÇÃO é
    # outra — local attacha no terminal daqui, remota só abre no navegador.
    out["group"] = server or "local"
    return out


def main() -> int:
    token = env("CP_AUTH_TOKEN")
    sessions: list[dict] = []
    errors: list[str] = []

    try:
        known = peers()
    except PanelError as e:
        known, _ = {}, errors.append(str(e))

    # (label, server_id, base_url, token, web_url) — local junto dos peers pra buscar tudo em
    # paralelo: sequencial, o custo era a SOMA das latências e um peer no timeout (4s) estourava
    # o intervalo de poll do painel. Em paralelo o pior caso é o servidor mais lento.
    targets = [("local", None, local_base(), token, "")]
    # TODO peer conhecido entra em servers[], ligado ou não: é a lista que o painel usa pra
    # desenhar o toggle. Sem ela, desligar um peer o apagaria da UI junto — e não sobraria botão
    # nenhum pra religar, só editar o peers.json na mão.
    servers: list[dict] = []
    for pid, cfg in known.items():
        on = enabled(cfg)
        servers.append({"id": pid, "enabled": on, "ok": False, "error": ""})
        # Desativado à mão: sai da varredura SEM virar linha de erro — é escolha do dono, não
        # falha. Um peer offline custava o timeout inteiro (4s) em TODO poll, e como o pior
        # servidor define o tempo da coleta, era o painel inteiro esperando por ele.
        if not on:
            continue
        # peer_fields valida TIPO: entrada não-dict ou base_url sem aspas estourava
        # AttributeError AQUI — neste laço, que roda FORA do try do worker — e matava a coleta
        # inteira, local junto. Peer malformado vira linha de erro, nunca derruba o painel.
        base, tok, web = peer_fields(cfg)
        if not base or not tok:
            errors.append(f"{pid}: entrada sem base_url/token válidos no peers.json")
            servers[-1]["error"] = "entrada inválida no peers.json"
            continue
        targets.append((pid, pid, base, tok, web or base))

    attached = attached_locally()
    by_id = {s["id"]: s for s in servers}

    def one(t: tuple) -> tuple:
        label, server, base, tok, web = t
        try:
            return label, server, [slim(s, server, web, attached) for s in fetch(base, tok)], None
        except Exception as e:   # falha de UM servidor nunca derruba a coleta dos outros
            return label, server, [], str(e)

    with ThreadPoolExecutor(max_workers=max(1, len(targets)) + 1) as pool:
        # Junto no pool: sequencial depois da varredura somaria a latencia do /api/projects
        # (probes de porta inclusos) ao pior servidor da malha.
        proj_future = pool.submit(fetch_projects, local_base(), token)
        for label, server, got, err in pool.map(one, targets):
            sessions += got
            if err:
                errors.append(f"{label}: {err}")
            # Casa por server_id, não pelo label: o local usa label "local" e um peer batizado
            # de "local" no peers.json sobrescreveria o resultado dele com o próprio.
            if server is not None and server in by_id:
                by_id[server]["ok"] = not err
                by_id[server]["error"] = err or ""

    # Ordem: bloco local primeiro (é onde dá pra agir direto), depois um bloco por servidor
    # remoto em ordem alfabética. DENTRO de cada bloco, awaiting_input primeiro (exige ação),
    # depois working, idle por último; nome desempata. A seção do painel depende desta ordem —
    # ListView agrupa por vizinhança, então registro fora de ordem quebraria o bloco em dois.
    rank = {"awaiting_input": 0, "working": 1}
    sessions.sort(key=lambda s: (s["server"] is not None, s["server"] or "",
                                 rank.get(s["state"], 2), s["name"]))
    projects, perr = proj_future.result()
    if perr:
        errors.append(perr)
    json.dump({"sessions": sessions, "errors": errors, "servers": servers,
               "projects": projects}, sys.stdout, ensure_ascii=False)
    print()
    return 0


if __name__ == "__main__":
    sys.exit(main())
