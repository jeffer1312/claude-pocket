#!/usr/bin/env python3
"""cp-panel-action <endereço> <operação> [args] — ações do menu de contexto do painel.

    info                 branch + arquivos modificados (pro cabeçalho do menu)
    rename <novo>        renomeia a sessão
    kill                 encerra a sessão tmux
    git <ação>           pull | fetch | status  (ações de LEITURA/atualização, sem reescrever)
    commit <msg>         commita TUDO que está modificado (sem push)
    push                 push da branch atual
    commit-push <msg>    commit + push numa tacada

Ops `peer` e `project` são exceções — o 1º argumento não é endereço de sessão:

    <servidor> peer on|off                liga/desliga o servidor na varredura (toggle do painel)
    <projeto> project start|stop|pane|open   launcher de projetos (projects.json, só local):
                                          play/stop, tail do log (pane) e log completo (open =
                                          terminal attachado na sessão do runner)

Tudo pela API do servidor DONO da sessão (endereço servidor::sessao funciona igual), então
rename/git valem também pras sessões remotas — o que NÃO dá remoto é só o attach no terminal.
Sempre imprime JSON: {"ok": bool, "message": str, ...}. O QML só mostra a message.
"""
import json
import os
import shutil
import subprocess
import sys

# resolve(): o script roda via symlink em ~/.local/bin — sem resolver, o import do módulo
# irmão procuraria em ~/.local/bin em vez de scripts/ do repo.
sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
from cp_panel_common import WRITE_TIMEOUT, PanelError, api, set_peer_enabled  # noqa: E402


def op_peer(pid: str, arg: str) -> dict:
    """Liga/desliga um peer na varredura. A gravação em si mora no cp_panel_common, junto da
    leitura do peers.json — PanelError sobe pro dispatcher e vira {"ok": false, message}."""
    if arg not in ("on", "off"):
        return {"ok": False, "message": "uso: cp-panel-action <servidor> peer on|off"}
    set_peer_enabled(pid, arg == "on")
    return {"ok": True, "message": f"{pid} {'ligado' if arg == 'on' else 'desligado'}"}


def op_project(name: str, action: str) -> dict:
    """Launcher de projetos (projects.json): o 1º argumento é o NOME DO PROJETO, não endereço
    de sessão — sempre no servidor local, que é onde os cwd existem."""
    if action == "start":
        r = api(name, "POST", "/api/projects/{name}/start", {}, timeout=WRITE_TIMEOUT)
        return {"ok": True, "message": f"iniciado ({r.get('state', '?')})", "project": r}
    if action == "stop":
        api(name, "POST", "/api/projects/{name}/stop", {}, timeout=WRITE_TIMEOUT)
        return {"ok": True, "message": "parado"}
    if action == "pane":
        r = api(name, "GET", "/api/projects/{name}/pane")
        return {"ok": True, "message": "", "pane": r.get("pane", "")}
    if action == "open":
        # Log completo: terminal attachado na sessão do runner (socket dedicado "cppkt-run",
        # mesmo nome do runner.SOCK do backend). Pane morto (remain-on-exit) também abre — é
        # exatamente o caso de inspecionar por que caiu.
        plist = api(name, "GET", "/api/projects")
        target = next((p.get("tmux") for p in plist if p.get("name") == name), "")
        if not target:
            return {"ok": False, "message": f"projeto '{name}' não está no projects.json"}
        term = next((t for t in ("kitty", "foot", "alacritty") if shutil.which(t)), None)
        if not term:
            return {"ok": False, "message": "nenhum terminal conhecido (kitty/foot/alacritty)"}
        subprocess.Popen([term, "-e", "tmux", "-L", "cppkt-run", "attach-session",
                          "-t", f"={target}"],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return {"ok": True, "message": "log aberto no terminal"}
    return {"ok": False, "message": "uso: cp-panel-action <projeto> project start|stop|pane|open"}


def op_project_add(name: str, rest: list) -> dict:
    """Cadastra/edita um projeto no projects.json local (POST /api/projects). rest = [cwd,
    command, port?]. name vazio/sem cwd/command -> o backend valida e devolve 400 legível."""
    cwd = rest[0] if len(rest) > 0 else ""
    command = rest[1] if len(rest) > 1 else ""
    body = {"name": name, "cwd": cwd, "command": command}
    if len(rest) > 2 and str(rest[2]).strip():
        try:
            body["port"] = int(rest[2])
        except ValueError:
            raise PanelError(f"porta inválida: {rest[2]!r}")
    r = api(name, "POST", "/api/projects", body, timeout=WRITE_TIMEOUT)
    return {"ok": True, "message": f"'{name}' salvo", "project": r}


def op_project_del(name: str) -> dict:
    """Remove um projeto do projects.json local (DELETE /api/projects/{name})."""
    api(name, "DELETE", "/api/projects/{name}", timeout=WRITE_TIMEOUT)
    return {"ok": True, "message": f"'{name}' removido"}


def op_info(addr: str) -> dict:
    sessions = api(addr, "GET", "/api/sessions")
    name = addr.split("::")[-1]
    branch = next((s.get("branch") for s in sessions if s.get("name") == name), None)
    try:
        files = api(addr, "GET", "/api/sessions/{name}/git/files")
        n = len(files if isinstance(files, list) else files.get("files", []))
    except PanelError as e:
        # SÓ "não é repo git" é caso normal (sessão em ~) e vira menu sem git. Rede caída ou
        # token errado tem que APARECER: engolir tudo aqui escondia falha real como se a pasta
        # simplesmente não tivesse git.
        if "not a git repository" not in str(e):
            raise
        return {"ok": True, "branch": "", "changed": 0, "git": False,
                "message": "sem repositório git"}
    return {"ok": True, "branch": branch or "?", "changed": n, "git": True,
            "message": f"{branch or '?'} · {n} modificado(s)"}


def op_commit(addr: str, msg: str, push: bool) -> dict:
    files = api(addr, "GET", "/api/sessions/{name}/git/files")
    items = files if isinstance(files, list) else files.get("files", [])
    paths = [f["path"] if isinstance(f, dict) else f for f in items]
    if not paths:
        return {"ok": False, "message": "nada modificado pra commitar"}
    api(addr, "POST", "/api/sessions/{name}/git/commit", {"message": msg, "paths": paths},
        timeout=WRITE_TIMEOUT)
    if not push:
        return {"ok": True, "message": f"commit de {len(paths)} arquivo(s)"}
    try:
        api(addr, "POST", "/api/sessions/{name}/git/push", timeout=WRITE_TIMEOUT)
    except PanelError as e:
        # Commit e push são chamadas separadas, sem transação: reportar só o erro do push
        # escondia que o commit JÁ EXISTE local. O usuário tentaria de novo e ouviria "nada
        # modificado" — sem nunca saber que tem commit pendente de push.
        return {"ok": False, "message": f"commit local OK ({len(paths)} arquivo(s)), push falhou: {e}"}
    return {"ok": True, "message": f"commit de {len(paths)} arquivo(s) + push"}


def main() -> int:
    if len(sys.argv) < 3:
        print(json.dumps({"ok": False, "message": "uso: cp-panel-action <endereço> <operação> [args]"}))
        return 2
    addr, op, rest = sys.argv[1], sys.argv[2], sys.argv[3:]

    try:
        if op == "info":
            out = op_info(addr)
        elif op == "rename":
            if not rest or not rest[0].strip():
                out = {"ok": False, "message": "nome vazio"}
            else:
                r = api(addr, "POST", "/api/sessions/{name}/rename", {"new": rest[0]})
                out = {"ok": True, "message": f"renomeada para {r.get('name', rest[0])}"}
        elif op == "kill":
            api(addr, "DELETE", "/api/sessions/{name}")
            out = {"ok": True, "message": "sessão encerrada"}
        elif op == "git":
            action = rest[0] if rest else "status"
            r = api(addr, "POST", "/api/sessions/{name}/git", {"action": action})
            # git_action devolve ok=False com a saída real quando o comando falha (ex: pull com
            # conflito). Propagar isso: dizer "pull ok" num merge sujo seria mentira.
            lines = [x for x in (r.get("output") or "").splitlines() if x.strip()]
            ok = bool(r.get("ok"))
            # PRIMEIRA linha, não a última: erro de git tem o motivo no topo ("fatal: Could not
            # read from remote repository.") e continuação embaixo — pegar o fim entregava
            # fragmento solto ("and the repository exists.") sem o motivo. No SUCESSO a primeira
            # linha do status é só o cabeçalho de branch ("## main"), daí somar a contagem.
            msg = lines[0] if lines else action
            # Contagem SÓ no status: é a única ação cuja saída é "cabeçalho + 1 linha por
            # arquivo". Em log/pull/fetch as demais linhas são commits e refs — rotular aquilo
            # de "arquivo(s)" seria número errado dito com confiança.
            if ok and action == "status" and len(lines) > 1:
                msg = f"{msg} · {len(lines) - 1} arquivo(s)"
            out = {"ok": ok, "message": msg[:140]}
        elif op == "commit":
            out = op_commit(addr, " ".join(rest) or "wip", push=False)
        elif op == "commit-push":
            out = op_commit(addr, " ".join(rest) or "wip", push=True)
        elif op == "project":
            # 1º argumento = nome de projeto do projects.json (local), não endereço de sessão.
            out = op_project(addr, rest[0] if rest else "")
        elif op == "project-add":
            out = op_project_add(addr, rest)
        elif op == "project-del":
            out = op_project_del(addr)
        elif op == "peer":
            # Único op cujo 1º argumento é um SERVIDOR, não um endereço de sessão: mexe no
            # peers.json local, sem chamar API nenhuma.
            out = op_peer(addr, rest[0] if rest else "")
        elif op == "push":
            api(addr, "POST", "/api/sessions/{name}/git/push", timeout=WRITE_TIMEOUT)
            out = {"ok": True, "message": "push feito"}
        else:
            out = {"ok": False, "message": f"operação desconhecida: {op}"}
    except PanelError as e:
        out = {"ok": False, "message": str(e)}

    print(json.dumps(out, ensure_ascii=False))
    return 0 if out.get("ok") else 1


if __name__ == "__main__":
    sys.exit(main())
