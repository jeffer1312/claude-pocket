# Python / uv
__pycache__/
*.pyc
.venv/
backend/.venv/

# Secrets / local env
.env
backend/.env
# peers de outros servidores (cp-send cross-server) — contém tokens
backend/peers.json
# Sidecars da gravação do toggle de peer: .lock (flock do read-modify-write) e .tmp (escrita
# atômica). O .tmp carrega a malha INTEIRA de tokens enquanto existe — nunca pode ser commitado.
backend/peers.json.lock
backend/peers.json.*.tmp

# Generated plan/spec HTML (created by local hook)
docs/superpowers/**/*.html

# SDD progress ledger (scratch)
.superpowers/

.claude-pocket-uploads/

# Video analysis scratch (video-analyzer skill)
*.mp4
*.analysis/
*.frames/
# local backend log
server.log
backend/server.log

# Test coverage
backend/.coverage

# Design mocks / experimentos locais (nao fazem parte do app)
frontend/animation-plan.*
frontend/public/lottie/
